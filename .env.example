# Local developer overrides. Copy this file to .env and fill in real values.

# Microsoft Edge executable path.
FUNDREL_EDGE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe

# Comma-separated proxies in host:port:user:pass format.
# Keep real proxy credentials only in .env or settings.json, never in code.
FUNDREL_PROXIES=

# Optional legacy/demo script values.
FUNDREL_PROXY_SERVER=http://proxy.example.com:10001
FUNDREL_PROXY_HOST=proxy.example.com
FUNDREL_PROXY_PORT=10001
FUNDREL_PROXY_USER=proxy-user
FUNDREL_PROXY_PASS=proxy-password
FUNDREL_DEMO_URL=https://example.com
FUNDREL_DEMO_EMAIL=person@example.com
FUNDREL_DEMO_PASSWORD=example-password
